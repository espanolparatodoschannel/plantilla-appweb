    "fichas": [
        {
            "id": 1,
            "categoria": "Functions",
            "tema": "Greeting",
            "explicacion": "These expressions are used to start friendly contact with others at different times of the day or night.",
            "ejemplos": {
                "formato": "lista",
                "items": [
                    "<strong>Hi</strong>! How are you today?",
                    "<strong>Good morning</strong>! How's it going?",
                    "<strong>Good afternoon</strong>! How's everything?",
                    "<strong>Hi</strong>, what's up, buddy?"
                ]
            },
            "consejo": "Use \"Hola\" at any time of day."
        },
        {
            "id": 2,
            "categoria": "Functions",
            "tema": "Responding to a greeting",
            "explicacion": "We use these simple phrases to react when someone greets us and we want to keep the conversation going politely.",
            "ejemplos": {
                "formato": "dialogo",
                "items": [
                    {
                        "pregunta": "Hi! How's it going?",
                        "respuesta": "Hi, <strong>fine</strong>, and you?"
                    },
                    {
                        "pregunta": "Good morning.",
                        "respuesta": "<strong>Good morning</strong>. Everything's great."
                    }
                ]
            },
            "consejo": "Return the question with a \"¿Y tú?\"."
        },
        {
            "id": 3,
            "categoria": "Functions",
            "tema": "Identifying",
            "explicacion": "We use these basic structures to say who we are or state our personal name to people who don't know us.",
            "ejemplos": {
                "formato": "lista",
                "items": [
                    "I <strong>am</strong> Mateo.",
                    "My name <strong>is</strong> Elena.",
                    "He <strong>is</strong> the teacher.",
                    "We <strong>are</strong> the new students."
                ]
            },
            "consejo": "Use the verb \"ser\" to identify yourself."
        },
        {
            "id": 4,
            "categoria": "Functions",
            "tema": "Addressing someone",
            "explicacion": "These short words help get someone's attention when we want to start talking to them directly.",
            "ejemplos": {
                "formato": "lista",
                "items": [
                    "<strong>Hey</strong>! Are you the new guy?",
                    "<strong>Excuse me</strong>, what's your name?",
                    "<strong>Look</strong>, there's the teacher.",
                    "<strong>Sorry</strong>, do you have a pen?"
                ]
            },
            "consejo": "Use \"Perdona\" to interrupt politely."
        },
        {
            "id": 5,
            "categoria": "Functions",
            "tema": "Responding to an introduction",
            "explicacion": "These are polite phrases we use right after meeting a new person to show our happiness and kindness.",
            "ejemplos": {
                "formato": "dialogo",
                "items": [
                    {
                        "pregunta": "I'm Mateo.",
                        "respuesta": "<strong>Nice to meet you</strong>, Mateo!"
                    },
                    {
                        "pregunta": "My name is Elena.",
                        "respuesta": "<strong>Pleased to meet you</strong>."
                    }
                ]
            },
            "consejo": " \"Encantado\" changes to \"Encantada\" if you are a woman."
        },
        {
            "id": 6,
            "categoria": "Grammar",
            "tema": "Proper names",
            "explicacion": "These are the special words we use to call people, tell them apart from others, and give them a unique identity.",
            "ejemplos": {
                "formato": "lista",
                "items": [
                    "My name is <strong>Elena</strong>.",
                    "My classmate is <strong>Mateo</strong>.",
                    "Her name is <strong>Lucía</strong>.",
                    "Is your name <strong>Pablo</strong>?"
                ]
            },
            "consejo": "Names always start with a capital letter."
        },
        {
            "id": 7,
            "categoria": "Grammar",
            "tema": "Subject pronoun",
            "explicacion": "These are brief terms that serve to indicate who is performing the action or who is speaking in a very simple sentence.",
            "ejemplos": {
                "formato": "lista",
                "items": [
                    "<strong>I</strong> am the student.",
                    "And how are <strong>you</strong> doing?",
                    "<strong>We</strong> are classmates now.",
                    "<strong>She</strong> is very nice."
                ]
            },
            "consejo": "Sometimes it's not necessary to use the pronoun."
        },
        {
            "id": 8,
            "categoria": "Grammar",
            "tema": "Present tense",
            "explicacion": "This basic verb tense is used to communicate actions happening right now or to describe current personal states.",
            "ejemplos": {
                "formato": "lista",
                "items": [
                    "I <strong>am</strong> doing great.",
                    "We <strong>are</strong> classmates today.",
                    "Elena <strong>is</strong> in class.",
                    "<strong>Are</strong> you the new guy?"
                ]
            },
            "consejo": "Master the verbs \"ser\" and \"estar\" first."
        },
        {
            "id": 9,
            "categoria": "Specific notions",
            "tema": "Name",
            "explicacion": "This refers to the vocabulary related to our official identity and how people call us in our everyday social environment.",
            "ejemplos": {
                "formato": "lista",
                "items": [
                    "How do you spell your <strong>name</strong>?",
                    "My <strong>last name</strong> is García.",
                    "What's your <strong>name</strong>?",
                    "The <strong>name</strong> is very pretty."
                ]
            },
            "consejo": "Practice spelling your own name."
        },
        {
            "id": 10,
            "categoria": "Spelling",
            "tema": "The alphabet",
            "explicacion": "This is the set of letters we use to form words and that allows us to spell proper names correctly.",
            "ejemplos": {
                "formato": "lista",
                "items": [
                    "It's spelled with an <strong>m</strong>.",
                    "Your name has an <strong>h</strong>.",
                    "Elena starts with an <strong>e</strong>.",
                    "My name has a <strong>t</strong>."
                ]
            },
            "consejo": "Vowels in Spanish always sound the same."
        },
        {
            "id": 11,
            "categoria": "Spelling",
            "tema": "Capital letters",
            "explicacion": "These are larger letters placed at the start of proper names to indicate they are names of people.",
            "ejemplos": {
                "formato": "lista",
                "items": [
                    "The name is <strong>M</strong>ateo.",
                    "My friend is <strong>E</strong>lena.",
                    "My name is <strong>L</strong>ucía.",
                    "Today is <strong>M</strong>onday."
                ]
            },
            "consejo": "Use capital letters only when necessary."
        }
    ],
